# Discord Configuration (Required)
DISCORD_BOT_TOKEN=your_discord_bot_token_here
GUILD_ID=your_guild_id_here
AUTH_CHANNEL_ID=your_auth_channel_id_here

# Security (Required - Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_64_character_random_hex_string_here
NUKE_PASSWORD=your_secure_nuke_password_here

# Server Configuration (Optional)
PORT=5050
NODE_ENV=production
LOG_LEVEL=info

# CORS (Optional - comma-separated list of allowed origins)
ALLOWED_ORIGINS=http://localhost:5050,https://yourdomain.com
